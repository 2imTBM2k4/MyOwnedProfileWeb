# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Admin Password (SERVER-SIDE - more secure)
# This is NOT exposed to the client
ADMIN_PASSWORD=your-secure-password-here

# Steam Web API Key (SERVER-SIDE only — no NEXT_PUBLIC_ prefix)
# Get yours at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key-here

# Discord ID for Lanyard integration (CLIENT-SIDE)
# Enable Developer Mode in Discord → Right-click your name → Copy ID
NEXT_PUBLIC_DISCORD_ID=your-discord-id-here

# RAWG API Key (SERVER-SIDE only)
# Get yours at: https://rawg.io/apidocs (free, 20,000 requests/month)
RAWG_API_KEY=your-rawg-api-key-here
